<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ChistiyDen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/na_blue</item>
        <item name="colorPrimaryVariant">@color/na_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_pressed</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorSurface">@color/card</item>
        <item name="colorOnSurface">@color/cream</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/card</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="bottomSheetDialogTheme">@style/Theme.ChistiyDen.BottomSheet</item>
    </style>

    <style name="Theme.ChistiyDen.BottomSheet" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.ChistiyDen.BottomSheet</item>
    </style>

    <style name="Widget.ChistiyDen.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:backgroundTint">@color/card</item>
    </style>

    <style name="Widget.ChistiyDen.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.ChistiyDen.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/line</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
