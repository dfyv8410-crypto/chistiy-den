<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp" app:cardCornerRadius="12dp"
    app:cardElevation="0dp" android:backgroundTint="@color/card"
    app:strokeColor="@color/line" app:strokeWidth="1dp"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:padding="12dp" android:gravity="center_vertical">
        <TextView android:id="@+id/bookTitle" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="wrap_content"
            android:textSize="14dp" android:textColor="@color/cream"
            android:textStyle="bold" android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/bookMeta" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12dp"
            android:textColor="@color/muted" android:paddingHorizontal="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
