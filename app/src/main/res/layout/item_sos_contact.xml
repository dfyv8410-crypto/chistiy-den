<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/card_border" android:padding="12dp"
    android:layout_marginBottom="6dp">
    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/sosName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13dp"
            android:textColor="@color/cream" android:textStyle="bold"/>
        <TextView android:id="@+id/sosDesc" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11dp"
            android:textColor="@color/muted"/>
    </LinearLayout>
    <Button android:id="@+id/sosCallBtn" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Позвонить"
        android:textSize="12dp" android:textStyle="bold"
        android:backgroundTint="#D4816A" android:textColor="@color/white"
        android:paddingHorizontal="14dp" style="@style/Widget.ChistiyDen.Button"/>
</LinearLayout>
