<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp" app:cardCornerRadius="12dp"
    app:cardElevation="0dp" android:backgroundTint="@color/card"
    app:strokeColor="@color/line" app:strokeWidth="1dp"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="14dp">
        <LinearLayout android:orientation="horizontal"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/cravingDate" android:textSize="13dp"
                android:textColor="@color/accent" android:textStyle="bold"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"/>
            <TextView android:id="@+id/cravingDuration" android:textSize="12dp"
                android:textColor="@color/muted" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <TextView android:id="@+id/cravingSituation" android:textSize="13dp"
            android:textColor="@color/cream" android:maxLines="2"
            android:ellipsize="end" android:layout_marginTop="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <LinearLayout android:id="@+id/cravingToolsRow"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="6dp"/>
        <TextView android:id="@+id/cravingStatus" android:textSize="11dp"
            android:textColor="@color/muted" android:textAllCaps="true"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
