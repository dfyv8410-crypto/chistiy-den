<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="16dp">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView android:id="@+id/homeGreeting" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Счётчик трезвости"
            android:textSize="20dp" android:textColor="@color/na_blue"
            android:fontFamily="serif" android:textStyle="bold" />
        <TextView android:id="@+id/settingsLink" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Изменить дату отсчёта"
            android:gravity="center" android:padding="12dp" android:layout_marginTop="16dp"
            android:background="@drawable/card_dashed" android:textColor="@color/na_blue"
            android:textStyle="bold" android:textSize="13dp"/>
        <!-- Medal circle -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:gravity="center"
            android:orientation="vertical" android:layout_marginTop="16dp">
            <View android:id="@+id/medalCircle" android:layout_width="160dp"
                android:layout_height="160dp" android:background="@drawable/circle_accent"
                android:layout_gravity="center" />
            <TextView android:id="@+id/daysCount" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0"
                android:textSize="48dp" android:textColor="@color/na_blue"
                android:fontFamily="serif" android:textStyle="bold"
                android:layout_marginTop="-100dp"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/days_clean"
                android:textSize="11dp" android:textColor="@color/muted"
                android:textAllCaps="true" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/medalName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Белая"
                android:textSize="14dp" android:textColor="@color/accent"
                android:textStyle="bold" android:background="@drawable/badge_accent"
                android:paddingHorizontal="16dp" android:paddingVertical="6dp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
        <!-- Progress bar -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:layout_marginTop="16dp">
            <androidx.appcompat.widget.AppCompatSeekBar
                android:id="@+id/progressBar" android:layout_width="match_parent"
                android:layout_height="8dp" android:progressDrawable="@drawable/progress_bar"
                android:max="100" android:progress="0" android:enabled="false"/>
        </LinearLayout>
        <!-- Stats -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:gravity="center" android:layout_marginTop="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:background="@drawable/card_border"
                android:padding="12dp">
                <TextView android:id="@+id/statDays" android:text="0"
                    android:textSize="20dp" android:textColor="@color/na_blue"
                    android:textStyle="bold" android:fontFamily="serif"/>
                <TextView android:text="Дней" android:textSize="10dp"
                    android:textColor="@color/muted" android:textAllCaps="true"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:background="@drawable/card_border"
                android:padding="12dp" android:layout_marginHorizontal="4dp">
                <TextView android:id="@+id/statMedal" android:text="-"
                    android:textSize="20dp" android:textColor="@color/na_blue"
                    android:textStyle="bold" android:fontFamily="serif"/>
                <TextView android:text="Медаль" android:textSize="10dp"
                    android:textColor="@color/muted" android:textAllCaps="true"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center"
                android:orientation="vertical" android:background="@drawable/card_border"
                android:padding="12dp">
                <TextView android:id="@+id/statNext" android:text="-"
                    android:textSize="20dp" android:textColor="@color/na_blue"
                    android:textStyle="bold" android:fontFamily="serif"/>
                <TextView android:text="До следующей" android:textSize="10dp"
                    android:textColor="@color/muted" android:textAllCaps="true"/>
            </LinearLayout>
        </LinearLayout>
        <TextView android:id="@+id/prayerText" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="20dp"
            android:padding="14dp" android:background="@drawable/card_border"
            android:text="@string/prayer_text"
            android:fontFamily="serif" android:textStyle="italic"
            android:textSize="13dp" android:textColor="@color/muted"
            android:lineSpacingExtra="4dp" android:gravity="center"
            android:letterSpacing="0.02"/>
    </LinearLayout>
</ScrollView>
