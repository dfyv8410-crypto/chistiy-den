<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/card_border" android:padding="10dp"
    android:layout_marginBottom="6dp">
    <CheckBox android:id="@+id/taskCheck" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:buttonTint="@color/accent"/>
    <TextView android:id="@+id/taskText" android:layout_width="0dp"
        android:layout_weight="1" android:layout_height="wrap_content"
        android:textSize="14dp" android:textColor="@color/cream"
        android:paddingHorizontal="8dp"/>
    <ImageButton android:id="@+id/taskDelete" android:layout_width="28dp"
        android:layout_height="28dp" android:src="@drawable/ic_close"
        android:background="@null" android:scaleType="center"
        android:contentDescription="Удалить"/>
</LinearLayout>
