<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FFF5EDE0"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Чистый день"
            android:textColor="#1A3E6B"
            android:textSize="28sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:indeterminateTint="#C8963E" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/pinOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#FFF5EDE0"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pin_title"
            android:textColor="#1A3E6B"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pin_hint"
            android:textColor="#8B7355"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/pinDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/pin_dot" android:layout_marginHorizontal="6dp" />
            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/pin_dot" android:layout_marginHorizontal="6dp" />
            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/pin_dot" android:layout_marginHorizontal="6dp" />
            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/pin_dot" android:layout_marginHorizontal="6dp" />
            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/pin_dot" android:layout_marginHorizontal="6dp" />
            <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/pin_dot" android:layout_marginHorizontal="6dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/pinError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C8963E"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <GridLayout
            android:id="@+id/pinGrid"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="3"
            android:rowCount="4"
            android:alignmentMode="alignMargins">

            <Button android:text="1" style="@style/PinKey" android:tag="1" />
            <Button android:text="2" style="@style/PinKey" android:tag="2" />
            <Button android:text="3" style="@style/PinKey" android:tag="3" />
            <Button android:text="4" style="@style/PinKey" android:tag="4" />
            <Button android:text="5" style="@style/PinKey" android:tag="5" />
            <Button android:text="6" style="@style/PinKey" android:tag="6" />
            <Button android:text="7" style="@style/PinKey" android:tag="7" />
            <Button android:text="8" style="@style/PinKey" android:tag="8" />
            <Button android:text="9" style="@style/PinKey" android:tag="9" />
            <Button android:text="⌫" style="@style/PinKey.Fn" android:tag="backspace" />
            <Button android:text="0" style="@style/PinKey" android:tag="0" />
            <View />

        </GridLayout>

    </LinearLayout>

</FrameLayout>
